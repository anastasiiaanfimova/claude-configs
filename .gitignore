# Block everything by default
*

# Runtime artifacts — never version
shell-snapshots/
session-env/
paste-cache/
project_clones/
.cache/
clipboard/
*.log
auth.json
*.key
*.pem
*.token
credentials.json
settings.local.json

# Explicitly allow what belongs in version control
!.gitignore
!README.md
!CLAUDE.md
!resources.md
!review-notes.md
!settings/
!settings/**
!agents/
!agents/**
!commands/
!commands/**
!hooks/
!hooks/**
!skills/
!skills/**
skills/push-config/replacements.md
!scripts/
!scripts/**
!examples/
!examples/**
!templates/
!templates/**
!lib/
!lib/**
# keep local-only deny list and target rules out (publish only .example)
lib/push-mirror/forbidden.txt
lib/push-mirror/replacements/*
!lib/push-mirror/replacements/example.md
hooks/pre-commit.local
