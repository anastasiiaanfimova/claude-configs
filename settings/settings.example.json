{
  "permissions": {
    "allow": [
      "mcp__<memory-mcp>__*",
      "Read(/tmp/*)",
      "Write(/tmp/*)",
      "Edit(/tmp/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "<bash-command-filter>"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat | <MEMORY_STORE_ENV>=$(bash ~/<memory-mcp-home>/detect-store.sh) ~/<memory-mcp-home>/bin/<memory-mcp> hook run --hook session-start --harness claude-code"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "<MEMORY_STORE_ENV>=$(bash ~/<memory-mcp-home>/detect-store.sh) cat | ~/<memory-mcp-home>/bin/<memory-mcp> hook run --hook stop --harness claude-code"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/<memory-store-normalize>.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "<conversation-archive-cli> sync",
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "<MEMORY_STORE_ENV>=$(bash ~/<memory-mcp-home>/detect-store.sh) cat | ~/<memory-mcp-home>/bin/<memory-mcp> hook run --hook stop --harness claude-code"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/<memory-store-normalize>.sh",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "<MEMORY_STORE_ENV>=$(bash ~/<memory-mcp-home>/detect-store.sh) cat | ~/<memory-mcp-home>/bin/<memory-mcp> hook run --hook precompact --harness claude-code",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'CWD=$(pwd); if ls \"$CWD\" 2>/dev/null | grep -qE \"^(package\\.json|go\\.mod|requirements\\.txt|Cargo\\.toml|pyproject\\.toml|build\\.gradle|\\.git)$\"; then if [ ! -d \"$CWD/<code-graph-dir>\" ]; then echo \"SETUP NEEDED: <code-graph-tool> not initialized in this project.\"; fi; fi'"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/<history-cleanup-script>.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/<orphan-mcp-killer>.sh --kill",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/<memory-mcp-health-check>.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "warp@claude-code-warp": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "hookify@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "effortLevel": "high",
  "theme": "dark-ansi",
  "model": "claude-opus-4-7"
}
