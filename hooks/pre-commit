#!/bin/bash
# Global pre-commit hook — blocks private project/service names from leaking into public repos.
#
# Install:
#   cp hooks/pre-commit ~/.git-hooks/pre-commit
#   chmod +x ~/.git-hooks/pre-commit
#   git config --global core.hooksPath ~/.git-hooks
#
# Single source of truth for the deny list:
#   ~/.claude/lib/push-mirror/forbidden.txt — one regex pattern per line.
#   Comments (#) and empty lines are ignored.
#
# To add a temporary or permanent forbidden word: edit forbidden.txt directly.

# --- Load scan pattern ---
FORBIDDEN_FILE="$HOME/.claude/lib/push-mirror/forbidden.txt"

[ -f "$FORBIDDEN_FILE" ] || exit 0

PATTERN=$(grep -vE '^\s*(#|$)' "$FORBIDDEN_FILE" | paste -sd '|' -)
[ -z "$PATTERN" ] && exit 0

# --- Config ---
OWNER="anastasiiaanfimova"   # only scan repos under this GitHub owner

# --- Check if this is a target repo ---
REMOTE_URL=$(git remote get-url origin 2>/dev/null)
if [[ "$REMOTE_URL" != *"github.com"*"$OWNER"* ]]; then
  exit 0
fi

# Check if repo is public (requires gh CLI; skips visibility check if gh unavailable)
if command -v gh &>/dev/null; then
  REPO_NAME=$(basename -s .git "$REMOTE_URL")
  VISIBILITY=$(gh api "repos/$OWNER/$REPO_NAME" --jq '.visibility' 2>/dev/null)
  if [[ "$VISIBILITY" != "public" ]]; then
    exit 0
  fi
fi

# --- Scan staged diff ---
matches=$(git diff --cached --unified=0 | grep "^+" | grep -iv "^+++" | grep -iE "$PATTERN")
if [ -n "$matches" ]; then
  echo "❌ pre-commit: private name found in staged diff (public repo: $REMOTE_URL):"
  echo "$matches"
  echo ""
  echo "Replace with a generic placeholder (e.g. <project>) before committing."
  exit 1
fi
